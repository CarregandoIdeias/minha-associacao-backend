DATABASE_URL=postgres://usuario:senha@host:5432/banco
JWT_SECRET=troque-por-um-segredo-forte-aqui
PORT=3000
NODE_ENV=development

# Origens permitidas pelo CORS, separadas por vírgula. Obrigatório em
# produção (NODE_ENV=production) — o servidor recusa subir sem isso.
# Ex: CORS_ORIGINS=https://painel.suaassociacao.com.br
CORS_ORIGINS=

# Segredo de uso único para criar o primeiro super-admin via
# POST /superadmin/bootstrap. Sem essa variável definida, a rota fica
# sempre bloqueada (falha segura). Gere algo forte e aleatório, use uma vez
# e pode até trocar depois — só o primeiro super-admin depende dela.
BOOTSTRAP_SECRET=troque-por-um-segredo-forte-aqui
